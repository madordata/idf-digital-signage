# Frontend → Backend API base URL (used by the ticker and screen content).
# Copy this file to `.env` and adjust if your backend runs elsewhere.
VITE_API_URL=http://localhost:4100

# Backend (server/server.js) listening port.
PORT=4100

# Google Sheet that drives all screen content (optional).
# Paste the long id from the sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
# Leave empty to use the built-in default content. The sheet must be shared as
# "Anyone with the link: Viewer". See GOOGLE_SHEETS_SETUP.md.
GOOGLE_SHEET_ID=
